generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Image {
  id Int @id @default(autoincrement())
  name String @unique
  url String @unique
  characters Character[]
  scores Score[]
}

model Character {
  id Int @id @default(autoincrement())
  name String @unique
  x Float
  y Float
  image Image @relation(fields: [imageId], references:[id])
  imageId Int 
}

model Score {
  id Int @id @default(autoincrement())
  time Float @unique
  playerName String @unique
  image Image @relation(fields: [imageId], references:[id])
  imageId Int 
}